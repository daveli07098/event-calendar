generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  password       String?          // hashed — null for OAuth-only users
  themeSettings  Json?            // persisted Theme object { mode, accent, radius, density, font }
  aiQuotaDate    String?          // "YYYY-MM-DD" day key for AI rate limiting
  aiQuotaCount   Int              @default(0) // AI scrape calls used on aiQuotaDate
  accounts       Account[]
  sessions       Session[]
  calendars      Calendar[]
  calendarMemberships CalendarMember[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Calendar {
  id               String           @id @default(cuid())
  userId           String           // owner
  name             String
  color            String           @default("#4285f4")
  isDefault        Boolean          @default(false)
  isVisible        Boolean          @default(true)
  googleCalendarId String?
  // Sharing
  shareToken       String?          @unique  // random token for invite URL; null = not shared
  shareMode        String?          // "collaborative" | "broadcast" | null
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  events  Event[]
  members CalendarMember[]

  @@index([userId])
}

// Tracks users who have joined a shared calendar
model CalendarMember {
  id         String   @id @default(cuid())
  calendarId String
  userId     String
  role       String   // "editor" | "viewer"
  joinedAt   DateTime @default(now())

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarId, userId])
  @@index([userId])
}

model Event {
  id             String   @id @default(cuid())
  calendarId     String
  title          String
  description    String?  @db.Text
  location       String?
  startTime      DateTime
  endTime        DateTime
  allDay         Boolean  @default(false)
  recurrenceRule String?
  googleEventId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId])
  @@index([startTime, endTime])
}

// Community venue directory — referenced when importing ticket events
model EventVenue {
  id        String   @id @default(cuid())
  name      String                      // primary/official name
  aliases   String[] @default([])       // other names used for the same venue
  address   String?                     // street address
  city      String   @default("Hong Kong")
  country   String   @default("HK")
  tags      String[] @default([])       // e.g. ["arena", "theatre", "concert-hall"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
