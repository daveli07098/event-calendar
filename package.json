    "@fullcalendar/timegrid": "^6.1.20",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@vercel/blob": "^2.3.3",
